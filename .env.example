# Supabase — projekt statki (eu-west-1)
# Skopiuj ten plik do .env.local i uzupełnij wartościami ze swojego projektu:
# Dashboard > Project Settings > API

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Opcjonalnie: service_role key
# UWAGA: NIGDY nie umieszczaj tego klucza w kodzie frontendowym!
# Używaj wyłącznie w Supabase Edge Functions lub skryptach serwerowych.
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
